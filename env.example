# Copy to `.env.local` (never commit secrets).

DATABASE_URL=

# SendGrid — Mail Send API (email from comms queue)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Twilio — Programmable SMS (must be E.164)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Set to "true" to skip real HTTP calls to providers (still writes compliance log as sent).
COMMS_PROVIDER_DRY_RUN=false

# KPI materialized views — POST /api/intelligence/kpi/refresh (optional; or use pg_cron + refresh_kpi_intel())
KPI_REFRESH_SECRET=

# Messaging orchestration — POST /api/messaging/orchestrator/tick (cron/worker; evaluates journeys → queue)
MESSAGING_ORCHESTRATOR_SECRET=
